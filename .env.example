# ------------------------------------------------------------------
# CVA Gestão — variáveis de ambiente
# Copie para `.env.local` e preencha. Nunca versione `.env.local`.
# ------------------------------------------------------------------

# Postgres. Em desenvolvimento, o docker-compose sobe um banco local.
# Em produção use a connection string do Supabase (pooler, porta 6543,
# com `?sslmode=require`).
DATABASE_URL="postgresql://cva:cva@localhost:5433/cva_gestao"

# Chave de assinatura da sessão (HS256). Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Mínimo de 32 bytes. Trocar esta chave invalida todas as sessões ativas.
AUTH_SECRET=""

# URL pública da aplicação (usada em links de convite e compartilhamento).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Storage — upload de avatares.
# Em branco: os arquivos vão para `public/uploads/` (driver local de dev).
# Preenchido: vão para o bucket do Supabase. O bucket precisa ser público.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="cva-media"

# E-mail transacional (recuperação de acesso, vaga liberada, times publicados).
# Em branco: o e-mail é impresso no terminal, com o link clicável — o fluxo
# inteiro funciona em desenvolvimento sem configurar provedor nenhum.
RESEND_API_KEY=""
EMAIL_FROM="CVA Gestão <nao-responda@seu-dominio.com.br>"

# Fuso e locale do clube (defaults gravados no seed de club_settings).
CLUB_TIMEZONE="America/Sao_Paulo"

# Permite rodar o seed de demonstração. Deve ficar "false" em produção:
# o seed é bloqueado quando NODE_ENV=production e esta flag não é "true".
ALLOW_DEMO_SEED="true"
